<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('[data-load-more-list]').forEach(function (list) {
      const items = Array.from(list.querySelectorAll('[data-load-more-item]'));
      const trigger = list.parentElement.querySelector('[data-load-more-trigger]');
      const loadCount = Number(list.dataset.loadCount || 3);

      if (!trigger) return;

      trigger.addEventListener('click', function () {
        const hiddenItems = items.filter(function (item) {
          return item.classList.contains('d-none');
        });

        hiddenItems.slice(0, loadCount).forEach(function (item) {
          item.classList.remove('d-none');
        });

        const hasMoreItems = items.some(function (item) {
          return item.classList.contains('d-none');
        });

        if (!hasMoreItems) {
          trigger.textContent = trigger.dataset.loadMoreCompleteLabel || '已顯示全部文章';
          trigger.disabled = true;
        }
      });
    });
  });
</script>
